.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# Ruff
.ruff_cache/

# Local configuration overrides
config/local.py

# Temporary files
*.tmp
*.temp
*.bak
*.swp
*~
test_setup.txt

